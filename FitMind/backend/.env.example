# FitMind Backend - Environment Variables
# Copy to .env and fill in your values
# ⚠️ NEVER commit .env or serviceAccountKey.json to git!

# === REQUIRED ===
GOOGLE_API_KEY=your-gemini-api-key-here
ENV=production
PORT=8000

# === DEVELOPMENT (optional) ===
# Secret pre testovacie endpointy (/api/test/*)
# Vygeneruj si vlastný: python -c "import secrets; print(secrets.token_urlsafe(32))"
DEV_SECRET=your-random-secret-here

# === OPTIONAL ===
AUDIT_LOGGING_ENABLED=true
ANTIBOT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100
AI_DAILY_MESSAGE_LIMIT=20
MAX_REQUEST_SIZE_MB=10
ALLOWED_ORIGINS=https://fitmind.sk,https://www.fitmind.sk

# === FIREBASE ===
# 1. Stiahni serviceAccountKey.json z Firebase Console
# 2. Ulož ho do backend/ priečinka
# 3. NIKDY ho nepridávaj do gitu!
