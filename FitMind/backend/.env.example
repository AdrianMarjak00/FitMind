# ⚠️ SECURITY NOTICE ⚠️
# This is an EXAMPLE file. Never commit your actual .env file!
# Copy this to .env and fill in your real values.
# The .env file is in .gitignore to prevent accidental commits.

# ==============================================================================
# GOOGLE GEMINI API KEY
# ==============================================================================
# Get your API key from: https://aistudio.google.com/app/apikey
# This key is used for AI chat functionality
GOOGLE_API_KEY=your-gemini-api-key-here

# ==============================================================================
# SERVER CONFIGURATION
# ==============================================================================
# Port for the server (8000 is default for FastAPI/uvicorn)
PORT=8000

# Environment: 'development' or 'production'
# In production, error messages are sanitized for security
ENV=development

# ==============================================================================
# CORS CONFIGURATION
# ==============================================================================
# Comma-separated list of allowed origins
# In production, this should be set to your actual frontend domains
ALLOWED_ORIGINS=http://localhost:4200,https://www.fit-mind.sk,https://fit-mind.sk

# ==============================================================================
# FIREBASE CONFIGURATION
# ==============================================================================
# Your Firebase service account JSON should be in:
# backend/serviceAccountKey.json
# 
# ⚠️ NEVER commit serviceAccountKey.json to git! ⚠️
# 
# To get this file:
# 1. Go to Firebase Console > Project Settings > Service Accounts
# 2. Click "Generate new private key"
# 3. Save as serviceAccountKey.json in the backend/ directory
# 4. Make sure it's in .gitignore (it already is!)

# ==============================================================================
# RATE LIMITING (Optional)
# ==============================================================================
# Maximum requests per minute per IP address (default: 100)
# RATE_LIMIT_PER_MINUTE=100

# Maximum AI chat messages per day per user (default: 5)
# AI_DAILY_MESSAGE_LIMIT=5

# ==============================================================================
# SECURITY (Optional)
# ==============================================================================
# Maximum request body size in MB (default: 10)
# MAX_REQUEST_SIZE_MB=10

# Maximum chat message length in characters (default: 2000)
# MAX_MESSAGE_LENGTH=2000

# ==============================================================================
# DEPLOYMENT NOTES
# ==============================================================================
# For Render.com deployment:
# 1. Add GOOGLE_API_KEY as environment variable in Render dashboard
# 2. Add serviceAccountKey.json as a Secret File
# 3. Set ENV=production
# 4. Set ALLOWED_ORIGINS to your production domain(s)
#
# DO NOT set these in a .env file on Render - use their dashboard!
